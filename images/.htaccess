# Disable execution of scripts in the upload folder
<FilesMatch "\.(php|phtml|php3|php4|php5|php6|php7|php8|phar|html|js|pl|py|sh|cgi)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Remove handler for PHP
RemoveHandler .php .phtml .phar
RemoveType .php .phtml .phar

# Prevent directory browsing
Options -Indexes
